# Copy to .env.local and fill in values from your Cognito User Pool + deployed API.
#
# Note: POST /query expects API Gateway JWT authorizer claims (Cognito sub/username).
# If the JWT authorizer is not attached to the HTTP API route, the Lambda will return 401.
#
# App clients WITH a client secret: set COGNITO_CLIENT_SECRET (server-only) and enable
# ALLOW_USER_PASSWORD_AUTH on the Cognito app client.
# Sign-up also needs self-registration enabled on the user pool (and usually email verification).

# Full API base URL (no trailing slash), e.g. https://abc123.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com

# Cognito User Pool (us-east-1 example: us-east-1_XXXXXXXXX)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Public app client ID
NEXT_PUBLIC_COGNITO_CLIENT_ID=YOUR_COGNITO_APP_CLIENT_ID

# Server-only: required when the app client has a client secret
COGNITO_CLIENT_SECRET=

# AWS region for the Cognito pool
NEXT_PUBLIC_AWS_REGION=us-east-1

# Server-only: S3 bucket for document uploads (same bucket as ingestion pipeline)
S3_BUCKET_NAME=rag-documents-YOUR_ACCOUNT_ID-us-east-1-an

# Optional: max PDF upload size in bytes (default 15 MB)
# MAX_UPLOAD_BYTES=15728640

# AWS credentials for local dev (upload + status routes).
# Needs s3:PutObject on intake/native/* and s3:GetObject/HeadObject on processed/* and manifest/*.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# The last successful upload is remembered per user in the browser.
# New users start without an active document.
