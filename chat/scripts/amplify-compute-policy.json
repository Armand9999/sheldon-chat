{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SheldonUploadIntake",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/intake/native/*"
    },
    {
      "Sid": "SheldonListBucketPrefixes",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["intake/native/*", "processed/*", "manifest/*"]
        }
      }
    },
    {
      "Sid": "SheldonReadProcessedAndManifest",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:HeadObject"],
      "Resource": [
        "arn:aws:s3:::YOUR_BUCKET_NAME/processed/*",
        "arn:aws:s3:::YOUR_BUCKET_NAME/manifest/*"
      ]
    },
    {
      "Sid": "SheldonCognitoAuth",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:InitiateAuth",
        "cognito-idp:SignUp",
        "cognito-idp:ConfirmSignUp",
        "cognito-idp:ResendConfirmationCode"
      ],
      "Resource": "arn:aws:cognito-idp:YOUR_REGION:YOUR_ACCOUNT_ID:userpool/YOUR_USER_POOL_ID"
    }
  ]
}
